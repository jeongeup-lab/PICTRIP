# EditorConfig — cross-tool defaults for the PicTrip monorepo.
# Line length is intentionally NOT set here; ruff (100) and prettier own that.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[*.{json,yaml,yml,md,ts,tsx,js,jsx,html,css}]
indent_size = 2

# Markdown trailing whitespace can be a hard line break; don't strip it.
[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
