# Per-directory secrets — keys only. Real values live on each host, never committed.

# ── backend/.env  (CT112: /opt/pictrip-api/.env) ──
# POSTGRES_HOST=
# POSTGRES_DB=pictrip
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# REDIS_URL=redis://localhost:6379/0
# KTO_API_KEY=
# KAKAO_REST_API_KEY=
# ANTHROPIC_API_KEY=
# ADMIN_PASSWORD=
# SENTRY_DSN=
# ENVIRONMENT=production

# ── mobile  (EXPO_PUBLIC_* only) ──
# EXPO_PUBLIC_API_BASE_URL=https://api.pictrip.org/v1

# ── pipeline/.env  (CT111) ──
# DATABASE_URL=postgresql://user:pass@CT110:5432/pictrip
# KTO_API_KEY=

# ── deploy/monitoring ──
# DISCORD_WEBHOOK_URL=

# ── web ──
# (none — .well-known link files are public)
